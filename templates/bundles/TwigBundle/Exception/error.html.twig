{# Page d'erreur générique — utilisée pour les codes sans template dédié #}
{% set catalog = {
    400: {
        title: 'Requête invalide',
        message: 'La demande envoyée au serveur est incorrecte ou mal formée.',
        icon: 'slash-circle',
        tone: 'warn',
        hint: 'Vérifiez les données saisies dans le formulaire, puis réessayez.',
        primary_label: 'Retour à l\'accueil',
        primary_url: path('app_home'),
        primary_icon: 'house',
    },
    408: {
        title: 'Délai dépassé',
        message: 'Le serveur n\'a pas reçu de réponse dans le temps imparti.',
        icon: 'clock-history',
        tone: 'warn',
        primary_label: 'Réessayer',
        primary_url: app.request.uri,
        primary_icon: 'arrow-clockwise',
        secondary_label: 'Accueil',
        secondary_url: path('app_home'),
        secondary_icon: 'house',
    },
    419: {
        title: 'Session expirée',
        message: 'Votre session a expiré ou le jeton de sécurité n\'est plus valide.',
        icon: 'hourglass-split',
        tone: 'warn',
        hint: 'Cela arrive souvent après une longue période d\'inactivité. Reconnectez-vous pour continuer.',
        primary_label: 'Se reconnecter',
        primary_url: path('app_login'),
        primary_icon: 'box-arrow-in-right',
    },
    429: {
        title: 'Trop de requêtes',
        message: 'Vous avez effectué trop de demandes en peu de temps.',
        icon: 'speedometer2',
        tone: 'warn',
        hint: 'Patientez quelques instants avant de réessayer.',
        primary_label: 'Réessayer',
        primary_url: app.request.uri,
        primary_icon: 'arrow-clockwise',
    },
    502: {
        title: 'Passerelle invalide',
        message: 'Le serveur a reçu une réponse invalide en amont.',
        icon: 'cloud-slash',
        tone: 'danger',
        primary_label: 'Réessayer',
        primary_url: app.request.uri,
        primary_icon: 'arrow-clockwise',
        secondary_label: 'Accueil',
        secondary_url: path('app_home'),
        secondary_icon: 'house',
    },
} %}

{% set info = catalog[status_code]|default({
    title: 'Une erreur est survenue',
    message: 'Quelque chose s\'est mal passé. Notre équipe a été informée si nécessaire.',
    icon: 'exclamation-triangle',
    tone: 'danger',
    primary_label: 'Retour à l\'accueil',
    primary_url: path('app_home'),
    primary_icon: 'house',
}) %}

{% include 'errors/_page.html.twig' with {
    code: status_code,
    title: info.title,
    message: info.message,
    icon: info.icon,
    tone: info.tone,
    hint: info.hint|default(null),
    primary_label: info.primary_label|default(null),
    primary_url: info.primary_url|default(null),
    primary_icon: info.primary_icon|default(null),
    secondary_label: info.secondary_label|default(null),
    secondary_url: info.secondary_url|default(null),
    secondary_icon: info.secondary_icon|default(null),
} %}
