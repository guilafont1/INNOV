{% extends 'base.html.twig' %}

{% block title %}{{ chapitre.titre }}{% endblock %}

{% block body %}
{% set headerActions %}
    {% if chapitre.module and chapitre.module.cours %}
        <a href="{{ path('app_cours_show', {id: chapitre.module.cours.id}) }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Cours
        </a>
    {% else %}
        <a href="{{ path('app_chapitre_index') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Liste
        </a>
    {% endif %}
    {% if is_granted('ROLE_ENSEIGNANT') %}
        <a href="{{ path('app_chapitre_edit', {id: chapitre.id}) }}" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i> Modifier
        </a>
        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="bi bi-trash me-1"></i> Supprimer
        </button>
    {% endif %}
{% endset %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: chapitre.module ? chapitre.module.titre : 'Chapitre',
    title: chapitre.titre,
    actions: headerActions
} only %}

<article class="reading-content mx-auto">
    {{ chapitre.contenu|nl2br }}

    {% if chapitre.fichierMedia %}
        <div class="mt-4 pt-4 border-top">
            <h2 class="h6 text-muted mb-2">Fichier média</h2>
            <p class="mb-0">{{ chapitre.fichierMedia }}</p>
        </div>
    {% endif %}
</article>

{% if is_granted('ROLE_ENSEIGNANT') %}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="deleteModalLabel">Supprimer ce chapitre</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-0">Confirmer la suppression de <strong>{{ chapitre.titre }}</strong>. Cette action est irréversible.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                <form method="post" action="{{ path('app_chapitre_delete', {id: chapitre.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chapitre.id) }}">
                    <button type="submit" class="btn btn-danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
