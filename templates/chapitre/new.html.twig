{% extends 'base.html.twig' %}

{% block title %}Nouveau chapitre — {{ module.titre }}{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: module.cours.titre,
    title: 'Nouveau chapitre',
    description: 'Module : ' ~ module.titre
} only %}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_row(form.titre) }}
                    {{ form_row(form.contenu) }}
                    {% if form.fichierMedia is defined %}
                        {{ form_row(form.fichierMedia) }}
                    {% endif %}

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-1"></i> Créer le chapitre
                        </button>
                        <a href="{{ path('app_cours_show', {id: module.cours.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
