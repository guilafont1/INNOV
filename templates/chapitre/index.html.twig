{% extends 'base.html.twig' %}

{% block title %}Chapitres{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    title: 'Chapitres',
    description: 'Liste des chapitres disponibles.'
} only %}

{% if chapitres is empty %}
    {% include 'partials/_empty_state.html.twig' with {
        icon: 'file-text',
        text: 'Aucun chapitre disponible pour le moment.'
    } only %}
{% else %}
    <div class="row g-3">
        {% for chapitre in chapitres %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5 mb-2">{{ chapitre.titre }}</h2>
                        <p class="text-muted small flex-grow-1 mb-3">
                            {{ chapitre.contenu|slice(0, 100) }}{% if chapitre.contenu|length > 100 %}…{% endif %}
                        </p>
                        {% if chapitre.module %}
                            <p class="text-muted small mb-3">
                                <i class="bi bi-layers me-1"></i> {{ chapitre.module.titre }}
                            </p>
                        {% endif %}
                        <div class="d-flex flex-wrap gap-2 mt-auto">
                            <a href="{{ path('app_chapitre_show', {id: chapitre.id}) }}" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye me-1"></i> Lire
                            </a>
                            {% if is_granted('ROLE_ENSEIGNANT') %}
                                <a href="{{ path('app_chapitre_edit', {id: chapitre.id}) }}" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-pencil me-1"></i> Modifier
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
