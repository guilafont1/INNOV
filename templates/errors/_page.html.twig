<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} — MERJ Learn</title>
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%23155E75'/%3E%3Ctext x='16' y='22' text-anchor='middle' fill='white' font-family='Sora,sans-serif' font-weight='700' font-size='18'%3EM%3C/text%3E%3C/svg%3E">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
</head>
<body>
    <div class="error-layout">
        <aside class="error-panel">
            <div class="error-panel__brand">MERJ Learn</div>
            <div class="error-panel__code" aria-hidden="true">{{ code }}</div>
            <p class="error-panel__tagline">
                Plateforme pédagogique de gestion des cours, classes et plannings.
            </p>
        </aside>

        <div class="error-content">
            <div class="error-content__wrap">
                <div class="error-content__icon error-content__icon--{{ tone|default('info') }}">
                    <i class="bi bi-{{ icon|default('exclamation-circle') }}" aria-hidden="true"></i>
                </div>

                <p class="text-muted small mb-1">Erreur {{ code }}</p>
                <h1 class="h4 mb-2">{{ title }}</h1>
                <p class="text-muted mb-4">{{ message }}</p>

                {% if hint is defined and hint %}
                    <div class="error-content__hint">
                        <i class="bi bi-lightbulb me-1"></i> {{ hint }}
                    </div>
                {% endif %}

                <div class="error-content__actions">
                    {% if primary_url is defined and primary_url and primary_label is defined and primary_label %}
                        <a href="{{ primary_url }}" class="btn btn-primary">
                            {% if primary_icon is defined and primary_icon %}
                                <i class="bi bi-{{ primary_icon }} me-1"></i>
                            {% endif %}
                            {{ primary_label }}
                        </a>
                    {% endif %}
                    {% if secondary_url is defined and secondary_url and secondary_label is defined and secondary_label %}
                        <a href="{{ secondary_url }}" class="btn btn-outline-secondary">
                            {% if secondary_icon is defined and secondary_icon %}
                                <i class="bi bi-{{ secondary_icon }} me-1"></i>
                            {% endif %}
                            {{ secondary_label }}
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</body>
</html>
