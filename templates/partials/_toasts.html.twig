<div class="toast-container-app" aria-live="polite" aria-atomic="true">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            {% set toastClass = label == 'success' ? 'text-bg-success' : (label == 'error' ? 'text-bg-danger' : 'text-bg-secondary') %}
            {% set icon = label == 'success' ? 'bi-check-circle' : (label == 'error' ? 'bi-exclamation-triangle' : 'bi-info-circle') %}
            <div class="toast toast-app {{ toastClass }}" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bi {{ icon }}"></i>
                        <span>{{ message }}</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fermer"></button>
                </div>
            </div>
        {% endfor %}
    {% endfor %}
</div>
