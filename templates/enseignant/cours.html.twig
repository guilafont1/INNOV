{% extends 'base.html.twig' %}

{% block title %}Mes Cours{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Espace enseignant',
    title: 'Mes cours',
    description: 'Créez et gérez l\'ensemble de vos contenus pédagogiques.',
    actions: '<a href="' ~ path('app_cours_new') ~ '" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Nouveau cours</a>'
} %}

{% if cours|length > 0 %}
    <div class="row g-3">
        {% for c in cours %}
            {% set totalChapitres = 0 %}
            {% for module in c.modules %}
                {% set totalChapitres = totalChapitres + module.chapitres|length %}
            {% endfor %}
            {% set isConfigured = c.modules|length > 0 %}
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h2 class="h6 mb-2">{{ c.titre }}</h2>
                        <p class="text-muted small flex-grow-1">{{ c.description|slice(0, 120) }}{% if c.description|length > 120 %}…{% endif %}</p>

                        <div class="row text-center g-2 mb-3 mt-2">
                            <div class="col-4">
                                <div class="small text-muted">Modules</div>
                                <div class="fw-semibold tabular-nums">{{ c.modules|length }}</div>
                            </div>
                            <div class="col-4">
                                <div class="small text-muted">Chapitres</div>
                                <div class="fw-semibold tabular-nums">{{ totalChapitres }}</div>
                            </div>
                            <div class="col-4">
                                <div class="small text-muted">Classes</div>
                                <div class="fw-semibold tabular-nums">{{ c.classes|length }}</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            {% if isConfigured %}
                                <span class="badge-role badge-role--etudiant"><i class="bi bi-check-circle me-1"></i>Configuré</span>
                            {% else %}
                                <span class="badge-role badge-role--enseignant"><i class="bi bi-gear me-1"></i>À configurer</span>
                            {% endif %}
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <a href="{{ path('app_cours_show', {id: c.id}) }}" class="btn btn-primary btn-sm"><i class="bi bi-eye"></i> Voir</a>
                            {% if not isConfigured %}
                                <a href="{{ path('app_cours_setup', {id: c.id}) }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-gear"></i> Configurer</a>
                            {% else %}
                                <a href="{{ path('app_module_new') }}?coursId={{ c.id }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i> Module</a>
                            {% endif %}
                            <a href="{{ path('app_cours_edit', {id: c.id}) }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i></a>
                            <form id="delete-cours-{{ c.id }}" method="post" action="{{ path('app_cours_delete', {id: c.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ c.id) }}">
                                <button type="button" class="btn btn-outline-danger btn-sm"
                                        data-confirm-delete
                                        data-confirm-form="delete-cours-{{ c.id }}"
                                        data-confirm-name="{{ c.titre }}"
                                        data-confirm-message="Ce cours et tout son contenu seront supprimés définitivement.">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    {% include 'partials/_empty_state.html.twig' with {
        icon: 'book',
        text: 'Aucun cours disponible.',
        cta_url: path('app_cours_new'),
        cta_label: 'Créer un cours'
    } %}
{% endif %}
{% endblock %}
