{% extends 'base.html.twig' %}

{% block title %}Planning - {{ classe.nom }}{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: classe.nom,
    title: 'Planning de la classe',
    description: classe.description ?? (classe.etudiants|length ~ ' étudiants · ' ~ classe.cours|length ~ ' cours'),
    actions: '<a href="' ~ path('enseignant_planning') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Retour au planning</a>'
} %}

{% if planning|length > 0 %}
    <div class="card">
        <div class="card-body p-0">
            <table class="table-app">
                <thead>
                    <tr>
                        <th>Événement</th>
                        <th>Cours</th>
                        <th>Type</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for evenement in planning %}
                        <tr>
                            <td>
                                <div class="fw-medium">{{ evenement.titre }}</div>
                                {% if evenement.description %}
                                    <div class="small text-muted">{{ evenement.description|slice(0, 80) }}</div>
                                {% endif %}
                            </td>
                            <td>{{ evenement.cours.titre }}</td>
                            <td><span class="planning-chip planning-chip--{{ evenement.type|default('cours') }} d-inline-block">{{ evenement.type|default('cours')|capitalize }}</span></td>
                            <td class="text-muted">{{ evenement.dateDebut|date('d/m/Y H:i') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% else %}
    {% include 'partials/_empty_state.html.twig' with {
        icon: 'calendar-event',
        text: 'Aucun événement planifié pour les cours de cette classe.'
    } %}
{% endif %}
{% endblock %}
