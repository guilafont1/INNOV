{% extends 'base.html.twig' %}

{% block title %}Planning - {{ cours.titre }}{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: cours.titre,
    title: 'Planning du cours',
    description: cours.description|slice(0, 120),
    actions: '<a href="' ~ path('enseignant_planning') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Retour au planning</a>'
} %}

{% if planning|length > 0 %}
    <div class="card">
        <div class="card-body p-0">
            <table class="table-app">
                <thead>
                    <tr>
                        <th>Événement</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Lieu</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for evenement in planning %}
                        {% set isToday = evenement.dateDebut|date('Y-m-d') == 'now'|date('Y-m-d') %}
                        {% set isPast = evenement.dateDebut < date() %}
                        <tr>
                            <td>
                                <div class="fw-medium">{{ evenement.titre }}</div>
                                {% if evenement.description %}
                                    <div class="small text-muted">{{ evenement.description|slice(0, 80) }}</div>
                                {% endif %}
                            </td>
                            <td><span class="planning-chip planning-chip--{{ evenement.type|default('cours') }} d-inline-block">{{ evenement.type|default('cours')|capitalize }}</span></td>
                            <td class="text-muted">{{ evenement.dateDebut|date('d/m/Y H:i') }}</td>
                            <td class="text-muted">{{ evenement.lieu ?? '—' }}</td>
                            <td>
                                {% if isToday %}
                                    <span class="badge-role badge-role--enseignant">Aujourd'hui</span>
                                {% elseif isPast %}
                                    <span class="text-muted small">Terminé</span>
                                {% else %}
                                    <span class="badge-role badge-role--etudiant">À venir</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% else %}
    {% include 'partials/_empty_state.html.twig' with {
        icon: 'calendar-event',
        text: 'Aucun événement planifié pour ce cours.'
    } %}
{% endif %}
{% endblock %}
