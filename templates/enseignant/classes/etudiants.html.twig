{% extends 'base.html.twig' %}

{% block title %}Gérer les Étudiants - {{ classe.nom }}{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: classe.nom,
    title: 'Gérer les étudiants',
    description: 'Ajoutez ou retirez des étudiants de cette classe.',
    actions: '<a href="' ~ path('enseignant_classe_show', {id: classe.id}) ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Retour</a>'
} %}

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'people', value: classe.etudiants|length, label: 'Inscrits' } %}
    </div>
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'person-plus', value: etudiantsDisponibles|length, label: 'Disponibles' } %}
    </div>
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'book', value: classe.cours|length, label: 'Cours' } %}
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white py-3">
                <h2 class="h6 mb-0">Étudiants de la classe ({{ classe.etudiants|length }})</h2>
            </div>
            <div class="card-body p-0">
                {% if classe.etudiants|length > 0 %}
                    <table class="table-app">
                        <thead>
                            <tr>
                                <th>Étudiant</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for etudiant in classe.etudiants %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="avatar">{{ etudiant.prenom|first }}{{ etudiant.nom|first }}</span>
                                            <div>
                                                <div class="fw-medium">{{ etudiant.prenom }} {{ etudiant.nom }}</div>
                                                <div class="small text-muted">{{ etudiant.email }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <form id="remove-etudiant-{{ etudiant.id }}" method="post" class="d-inline">
                                            <input type="hidden" name="action" value="remove">
                                            <input type="hidden" name="etudiant_id" value="{{ etudiant.id }}">
                                            <button type="button" class="btn btn-outline-danger btn-sm"
                                                    data-confirm-delete
                                                    data-confirm-form="remove-etudiant-{{ etudiant.id }}"
                                                    data-confirm-name="{{ etudiant.prenom }} {{ etudiant.nom }}"
                                                    data-confirm-message="L'étudiant sera retiré de cette classe.">
                                                <i class="bi bi-person-dash"></i> Retirer
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="p-4">
                        {% include 'partials/_empty_state.html.twig' with { icon: 'people', text: 'Aucun étudiant dans cette classe.' } %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white py-3">
                <h2 class="h6 mb-0">Étudiants disponibles ({{ etudiantsDisponibles|length }})</h2>
            </div>
            <div class="card-body p-0">
                {% if etudiantsDisponibles|length > 0 %}
                    <table class="table-app">
                        <thead>
                            <tr>
                                <th>Étudiant</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for etudiant in etudiantsDisponibles %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="avatar">{{ etudiant.prenom|first }}{{ etudiant.nom|first }}</span>
                                            <div>
                                                <div class="fw-medium">{{ etudiant.prenom }} {{ etudiant.nom }}</div>
                                                <div class="small text-muted">{{ etudiant.email }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <form method="post" class="d-inline">
                                            <input type="hidden" name="action" value="add">
                                            <input type="hidden" name="etudiant_id" value="{{ etudiant.id }}">
                                            <button type="submit" class="btn btn-primary btn-sm">
                                                <i class="bi bi-person-plus"></i> Ajouter
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="p-4">
                        {% include 'partials/_empty_state.html.twig' with { icon: 'person-check', text: 'Tous les étudiants sont déjà assignés.' } %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
