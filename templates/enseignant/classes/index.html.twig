{% extends 'base.html.twig' %}

{% block title %}Mes Classes{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Espace enseignant',
    title: 'Mes classes',
    description: 'Consultez et gérez les classes dont vous êtes responsable.'
} %}

{% if classes|length > 0 %}
    <div class="row g-3">
        {% for classe in classes %}
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h2 class="h6 mb-2">{{ classe.nom }}</h2>
                        {% if classe.description %}
                            <p class="text-muted small flex-grow-1">{{ classe.description|slice(0, 100) }}{% if classe.description|length > 100 %}…{% endif %}</p>
                        {% endif %}
                        <div class="d-flex flex-wrap gap-3 small text-muted my-3">
                            <span><i class="bi bi-people me-1"></i>{{ classe.etudiants|length }} étudiant(s)</span>
                            <span><i class="bi bi-book me-1"></i>{{ classe.cours|length }} cours</span>
                            <span><i class="bi bi-calendar3 me-1"></i>{{ classe.createdAt|date('d/m/Y') }}</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a href="{{ path('enseignant_classe_show', {id: classe.id}) }}" class="btn btn-primary btn-sm"><i class="bi bi-eye"></i> Voir</a>
                            <a href="{{ path('enseignant_classe_notes', {id: classe.id}) }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-clipboard-data"></i> Notes</a>
                            <a href="{{ path('enseignant_classe_etudiants', {id: classe.id}) }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-person-plus"></i> Étudiants</a>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    {% include 'partials/_empty_state.html.twig' with {
        icon: 'people',
        text: 'Vous n\'êtes assigné à aucune classe pour le moment.'
    } %}
{% endif %}
{% endblock %}
