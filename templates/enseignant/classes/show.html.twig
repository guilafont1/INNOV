{% extends 'base.html.twig' %}

{% block title %}Classe {{ classe.nom }}{% endblock %}

{% block body %}
{% set totalModules = 0 %}
{% for c in cours %}
    {% set totalModules = totalModules + c.modules|length %}
{% endfor %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Classe',
    title: classe.nom,
    description: classe.description,
    actions: '<a href="' ~ path('enseignant_classes') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Retour</a>'
} %}

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'people', value: etudiants|length, label: 'Étudiants' } %}
    </div>
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'book', value: cours|length, label: 'Cours' } %}
    </div>
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'collection', value: totalModules, label: 'Modules' } %}
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="{{ path('enseignant_classe_notes', {id: classe.id}) }}" class="btn btn-primary btn-sm"><i class="bi bi-clipboard-data"></i> Gérer les notes</a>
    <a href="{{ path('enseignant_planning') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-calendar-week"></i> Voir le planning</a>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h2 class="h6 mb-0">Étudiants ({{ etudiants|length }})</h2>
            </div>
            <div class="card-body p-0">
                {% if etudiants|length > 0 %}
                    <table class="table-app">
                        <thead>
                            <tr>
                                <th>Étudiant</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for etudiant in etudiants %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="avatar">{{ etudiant.prenom|first }}{{ etudiant.nom|first }}</span>
                                            <div>
                                                <div class="fw-medium">{{ etudiant.prenom }} {{ etudiant.nom }}</div>
                                                <div class="small text-muted">{{ etudiant.email }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        {% set nbNotes = notesParEtudiant[etudiant.id]|default([])|length %}
                                        {% if nbNotes > 0 %}
                                            <span class="badge-role badge-role--etudiant">{{ nbNotes }} note(s)</span>
                                        {% else %}
                                            <span class="text-muted small">Aucune</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="p-4">
                        {% include 'partials/_empty_state.html.twig' with { icon: 'people', text: 'Aucun étudiant dans cette classe.' } %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white py-3">
                <h2 class="h6 mb-0">Cours ({{ cours|length }})</h2>
            </div>
            <div class="card-body p-0">
                {% if cours|length > 0 %}
                    <table class="table-app">
                        <thead>
                            <tr>
                                <th>Cours</th>
                                <th>Modules</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for c in cours %}
                                <tr>
                                    <td class="fw-medium">{{ c.titre }}</td>
                                    <td class="text-muted tabular-nums">{{ c.modules|length }}</td>
                                    <td class="text-end">
                                        <a href="{{ path('app_cours_show', {id: c.id}) }}" class="btn-icon-ghost" aria-label="Voir le cours">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="p-4">
                        {% include 'partials/_empty_state.html.twig' with { icon: 'book', text: 'Aucun cours assigné à cette classe.' } %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
