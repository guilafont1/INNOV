{% extends 'base.html.twig' %}

{% block title %}Dashboard Enseignant{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Espace enseignant',
    title: 'Tableau de bord',
    description: 'Gérez vos cours, suivez vos étudiants et consultez votre planning.',
    actions: '<a href="' ~ path('app_cours_new') ~ '" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Nouveau cours</a>'
} %}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'book', value: stats.totalCours ?? 0, label: 'Cours' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'collection', value: stats.totalModules ?? 0, label: 'Modules' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'journal-text', value: stats.totalChapitres ?? 0, label: 'Chapitres' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'people', value: stats.totalEtudiants ?? 0, label: 'Étudiants' } %}
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h2 class="h6 mb-0">Mes cours</h2>
                {% if totalCours > 5 %}
                    <a href="{{ path('enseignant_cours') }}" class="btn btn-sm btn-outline-primary">Voir tout ({{ totalCours }})</a>
                {% endif %}
            </div>
            <div class="card-body">
                {% if cours|length > 0 %}
                    <div class="row g-3">
                        {% for c in cours %}
                            {% set progressionMoyenne = 0 %}
                            {% if c.progressions|length > 0 %}
                                {% set totalAvancement = 0 %}
                                {% for p in c.progressions %}
                                    {% set totalAvancement = totalAvancement + (p.avancement ?? 0) %}
                                {% endfor %}
                                {% set progressionMoyenne = (totalAvancement / c.progressions|length)|round %}
                            {% endif %}
                            <div class="col-md-6">
                                <div class="card h-100">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2 dropdown-elevated">
                                            <h3 class="h6 mb-0">{{ c.titre }}</h3>
                                            <div class="dropdown">
                                                <button class="btn-icon-ghost" type="button" data-bs-toggle="dropdown" aria-label="Actions">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li><a class="dropdown-item" href="{{ path('app_cours_show', {id: c.id}) }}"><i class="bi bi-eye me-2"></i>Voir</a></li>
                                                    <li><a class="dropdown-item" href="{{ path('app_cours_edit', {id: c.id}) }}"><i class="bi bi-pencil me-2"></i>Modifier</a></li>
                                                    <li><a class="dropdown-item" href="{{ path('app_module_new') }}?coursId={{ c.id }}"><i class="bi bi-plus me-2"></i>Ajouter module</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <form id="delete-cours-{{ c.id }}" method="post" action="{{ path('app_cours_delete', {id: c.id}) }}">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ c.id) }}">
                                                        </form>
                                                        <button type="button" class="dropdown-item text-danger"
                                                                data-confirm-delete
                                                                data-confirm-form="delete-cours-{{ c.id }}"
                                                                data-confirm-name="{{ c.titre }}"
                                                                data-confirm-message="Ce cours et tout son contenu seront supprimés définitivement.">
                                                            <i class="bi bi-trash me-2"></i>Supprimer
                                                        </button>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                        <p class="text-muted small mb-2">{{ c.description|slice(0, 80) }}{% if c.description|length > 80 %}…{% endif %}</p>
                                        <div class="d-flex justify-content-between align-items-center small text-muted mb-2">
                                            <span><i class="bi bi-layers me-1"></i>{{ c.modules|length }} module(s)</span>
                                            <span><i class="bi bi-calendar3 me-1"></i>{{ c.createdAt ? c.createdAt|date('d/m/Y') : '—' }}</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress-thin flex-grow-1">
                                                <div class="progress-thin__fill" style="width: {{ progressionMoyenne }}%"></div>
                                            </div>
                                            <span class="small text-muted tabular-nums">{{ progressionMoyenne }}%</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    {% include 'partials/_empty_state.html.twig' with {
                        icon: 'book',
                        text: 'Aucun cours créé. Commencez par créer votre premier cours.',
                        cta_url: path('app_cours_new'),
                        cta_label: 'Créer un cours'
                    } %}
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h2 class="h6 mb-0">Événements à venir</h2>
                <a href="{{ path('enseignant_planning') }}" class="btn btn-sm btn-outline-primary">Planning</a>
            </div>
            <div class="card-body">
                {% if evenementsAvenir|length > 0 %}
                    <ul class="event-list list-unstyled mb-0">
                        {% for evenement in evenementsAvenir %}
                            <li class="event-item mb-2">
                                <a href="{{ path('enseignant_planning', {date: evenement.dateDebut|date('Y-m-d')}) }}" class="dashboard-event-link p-2">
                                    <div class="d-flex align-items-start gap-2">
                                        <span class="event-type-dot event-type-dot--{{ evenement.type|default('autre') }} mt-1"></span>
                                        <div class="min-w-0">
                                            <div class="small text-muted">{{ evenement.dateDebut|planning_short_date }}</div>
                                            <div class="fw-medium text-truncate">{{ evenement.titre }}</div>
                                            {% if evenement.lieu %}
                                                <div class="small text-muted text-truncate">{{ evenement.lieu }}</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    {% include 'partials/_empty_state.html.twig' with {
                        icon: 'calendar-event',
                        text: 'Aucun événement planifié.',
                        cta_url: path('enseignant_planning'),
                        cta_label: 'Voir le planning'
                    } %}
                {% endif %}
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white py-3">
                <h2 class="h6 mb-0">Activité récente</h2>
            </div>
            <div class="card-body">
                {% if activiteRecente|length > 0 %}
                    <ul class="activity-list">
                        {% for activite in activiteRecente %}
                            <li class="activity-item">
                                <div class="activity-item__icon">
                                    <i class="bi bi-{{ activite.type == 'cours_created' ? 'book' : 'clock-history' }}"></i>
                                </div>
                                <div>
                                    <div class="activity-item__text">{{ activite.message }}</div>
                                    <div class="activity-item__meta">{{ activite.date|date('d/m/Y H:i') }}</div>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    {% include 'partials/_empty_state.html.twig' with {
                        icon: 'clock-history',
                        text: 'Aucune activité récente.'
                    } %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
