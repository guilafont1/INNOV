{% extends 'base_public.html.twig' %}

{% block title %}Connexion — MERJ Learn{% endblock %}

{% block layout %}
    <div class="login-layout">
        <aside class="login-panel">
            <div class="login-panel__logo">MERJ Learn</div>
            <p class="login-panel__baseline">
                Plateforme pédagogique de gestion des cours, classes et plannings.
            </p>
        </aside>

        <div class="login-form-side">
            <div class="login-form-wrap">
                <h1 class="h4 mb-1">Connexion</h1>
                <p class="text-muted mb-4">Accédez à votre espace personnel</p>

                {% if error %}
                    <div class="alert-tint-danger mb-3" role="alert">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <p class="text-muted mb-3">
                        Vous êtes connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                    </p>
                    <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary">Se déconnecter</a>
                {% else %}
                    <form method="post">
                        <div class="mb-3">
                            <label for="username" class="form-label">Email</label>
                            <input type="email" name="_username" id="username" class="form-control"
                                   value="{{ last_username }}" required autofocus autocomplete="email"
                                   placeholder="votre.email@exemple.com">
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label">Mot de passe</label>
                            <input type="password" name="_password" id="password" class="form-control"
                                   required autocomplete="current-password"
                                   placeholder="Votre mot de passe">
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button class="btn btn-primary w-100" type="submit">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Se connecter
                        </button>
                    </form>

                    <p class="text-center text-muted small mt-4 mb-0">
                        Pas encore de compte ?
                        <a href="{{ path('app_register') }}">Inscrivez-vous</a>
                    </p>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
