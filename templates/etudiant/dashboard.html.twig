{% extends 'base.html.twig' %}

{% block title %}Dashboard Étudiant{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Espace étudiant',
    title: 'Tableau de bord',
    description: 'Suivez vos cours, votre progression et vos prochains événements.',
    actions: '<a href="' ~ path('app_cours') ~ '" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Découvrir les cours</a>'
} %}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'book', value: stats.totalCours ?? 0, label: 'Cours inscrits' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'collection', value: stats.totalModules ?? 0, label: 'Modules' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'journal-text', value: stats.totalChapitres ?? 0, label: 'Chapitres' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'graph-up', value: (stats.progressionMoyenne ?? 0) ~ '%', label: 'Progression moyenne' } %}
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h2 class="h6 mb-0">Mes cours</h2>
                {% if totalCours > 5 %}
                    <a href="{{ path('app_cours') }}" class="btn btn-sm btn-outline-primary">Voir tout ({{ totalCours }})</a>
                {% endif %}
            </div>
            <div class="card-body">
                {% if cours|length > 0 %}
                    <div class="row g-3">
                        {% for item in cours %}
                            {% set c = item.cours %}
                            <div class="col-md-6">
                                <div class="card h-100">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h3 class="h6 mb-0">{{ c.titre }}</h3>
                                            <span class="badge-role badge-role--{{ item.progression < 30 ? 'admin' : (item.progression < 70 ? 'enseignant' : 'etudiant') }}">{{ item.statut|capitalize }}</span>
                                        </div>
                                        <p class="text-muted small mb-2">{{ c.description|slice(0, 80) }}{% if c.description|length > 80 %}…{% endif %}</p>
                                        <div class="d-flex justify-content-between align-items-center small text-muted mb-2">
                                            <span><i class="bi bi-layers me-1"></i>{{ c.modules|length }} module(s)</span>
                                            <span><i class="bi bi-calendar3 me-1"></i>{{ c.createdAt ? c.createdAt|date('d/m/Y') : '—' }}</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-2 mb-3">
                                            <div class="progress-thin flex-grow-1">
                                                <div class="progress-thin__fill" style="width: {{ item.progression }}%"></div>
                                            </div>
                                            <span class="small text-muted tabular-nums">{{ item.progression }}%</span>
                                        </div>
                                        <a href="{{ path('app_cours_show', {id: c.id}) }}" class="btn btn-primary btn-sm"><i class="bi bi-play-fill"></i> Continuer</a>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    {% include 'partials/_empty_state.html.twig' with {
                        icon: 'mortarboard',
                        text: 'Aucun cours suivi. Découvrez nos contenus pédagogiques.',
                        cta_url: path('app_cours'),
                        cta_label: 'Découvrir les cours'
                    } %}
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h2 class="h6 mb-0">Événements à venir</h2>
                <a href="{{ path('etudiant_planning') }}" class="btn btn-sm btn-outline-primary">Planning</a>
            </div>
            <div class="card-body">
                {% if evenementsAvenir is defined and evenementsAvenir|length > 0 %}
                    <ul class="event-list list-unstyled mb-0">
                        {% for evenement in evenementsAvenir %}
                            <li class="event-item mb-2">
                                <a href="{{ path('etudiant_planning', {date: evenement.dateDebut|date('Y-m-d')}) }}" class="dashboard-event-link p-2">
                                    <div class="d-flex align-items-start gap-2">
                                        <span class="event-type-dot event-type-dot--{{ evenement.type|default('autre') }} mt-1"></span>
                                        <div class="min-w-0">
                                            <div class="small text-muted">{{ evenement.dateDebut|planning_short_date }}</div>
                                            <div class="fw-medium text-truncate">{{ evenement.titre }}</div>
                                            {% if evenement.lieu %}
                                                <div class="small text-muted text-truncate">{{ evenement.lieu }}</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    {% include 'partials/_empty_state.html.twig' with {
                        icon: 'calendar-event',
                        text: 'Aucun événement à venir.'
                    } %}
                {% endif %}
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white py-3">
                <h2 class="h6 mb-0">Activité récente</h2>
            </div>
            <div class="card-body">
                {% if activiteRecente|length > 0 %}
                    <ul class="activity-list">
                        {% for activite in activiteRecente %}
                            <li class="activity-item">
                                <div class="activity-item__icon">
                                    <i class="bi bi-{{ activite.type == 'progression_update' ? 'journal-text' : 'clock-history' }}"></i>
                                </div>
                                <div>
                                    <div class="activity-item__text">{{ activite.message }}</div>
                                    <div class="activity-item__meta">{{ activite.date|date('d/m/Y H:i') }}</div>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    {% include 'partials/_empty_state.html.twig' with {
                        icon: 'clock-history',
                        text: 'Aucune activité récente.'
                    } %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
