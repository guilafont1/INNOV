{% extends 'base.html.twig' %}

{% block title %}Mes notes{% endblock %}

{% block body %}
{% set gradeClass = moyenneGenerale < 10 ? 'note-grade--low' : (moyenneGenerale < 12 ? 'note-grade--mid' : 'note-grade--ok') %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Espace étudiant',
    title: 'Mes notes',
    description: 'Consultez vos résultats par cours et par module.',
    actions: '<a href="' ~ path('etudiant_dashboard') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Retour</a>'
} %}

<div class="note-summary">
    <div class="small text-muted mb-1">Moyenne générale</div>
    <div class="note-summary__value {{ gradeClass }} tabular-nums">{{ moyenneGenerale }} <span class="fs-5 text-muted">/ 20</span></div>
</div>

{% if notesParCours|length == 0 %}
    {% include 'partials/_empty_state.html.twig' with {
        icon: 'clipboard-data',
        text: 'Aucune note disponible pour le moment.'
    } %}
{% else %}
    {% for coursBlock in notesParCours %}
        <div class="card mb-4">
            <div class="card-header bg-white py-3">
                <h2 class="h6 mb-0"><i class="bi bi-book me-2"></i>{{ coursBlock.cours.titre }}</h2>
            </div>
            <div class="card-body">
                {% for moduleBlock in coursBlock.modules %}
                    <h3 class="h6 text-muted mb-3"><i class="bi bi-layers me-2"></i>{{ moduleBlock.module.titre }}</h3>
                    <div class="table-responsive mb-4">
                        <table class="table-app">
                            <thead>
                                <tr>
                                    <th class="num">Note</th>
                                    <th class="num">%</th>
                                    <th>Commentaire</th>
                                    <th>Professeur</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for note in moduleBlock.notes %}
                                    {% set percentage = note.pourcentage %}
                                    {% set pctClass = percentage >= 80 ? 'note-grade--ok' : (percentage >= 60 ? 'note-grade--mid' : 'note-grade--low') %}
                                    <tr>
                                        <td class="num note-value">{{ note.note }} / {{ note.noteMax }}</td>
                                        <td class="num fw-medium {{ pctClass }}">{{ percentage }}%</td>
                                        <td>{{ note.commentaire ?? '—' }}</td>
                                        <td>
                                            {% if note.professeur %}
                                                {{ note.professeur.prenom }} {{ note.professeur.nom }}
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td class="text-muted">{{ note.createdAt|date('d/m/Y') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endfor %}
{% endif %}
{% endblock %}
