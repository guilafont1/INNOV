{% extends 'base.html.twig' %}

{% block title %}{{ cours.titre }}{% endblock %}

{% block body %}
{% set totalChapitres = 0 %}
{% for module in modules %}
    {% set totalChapitres = totalChapitres + module.chapitres|length %}
{% endfor %}

{% set headerActions %}
    {% if is_granted('ROLE_ENSEIGNANT') and cours.createdBy == app.user %}
        <a href="{{ path('app_cours_edit', {id: cours.id}) }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i> Modifier
        </a>
        <a href="{{ path('app_module_new') }}?coursId={{ cours.id }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Module
        </a>
    {% endif %}
{% endset %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Cours',
    title: cours.titre,
    description: cours.description,
    actions: headerActions
} only %}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'layers', value: modules|length, label: 'Modules' } only %}
    </div>
    <div class="col-6 col-md-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'file-text', value: totalChapitres, label: 'Chapitres' } only %}
    </div>
    <div class="col-6 col-md-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'people', value: cours.classes|length, label: 'Classes' } only %}
    </div>
    <div class="col-6 col-md-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'person-check', value: cours.progressions|length, label: 'Étudiants' } only %}
    </div>
</div>

{% if progression is defined and progression %}
    {% set consulted_ids = progression.chapitresConsultees|map(c => c.id)|default([]) %}
{% else %}
    {% set consulted_ids = [] %}
{% endif %}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h5 mb-0">Modules et chapitres</h2>
    {% if is_granted('ROLE_ENSEIGNANT') and cours.createdBy == app.user and modules|length > 0 %}
        <div class="dropdown">
            <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-plus-lg me-1"></i> Chapitre
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                {% for module in modules %}
                    <li>
                        <a class="dropdown-item" href="{{ path('app_chapitre_new_from_module', {id: module.id}) }}">
                            {{ module.titre }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
</div>

{% if modules|length > 0 %}
    <div class="accordion mb-4" id="modulesAccordion">
        {% for module in modules %}
            <div class="accordion-item">
                <h3 class="accordion-header" id="module-heading-{{ module.id }}">
                    <button class="accordion-button {% if not loop.first %}collapsed{% endif %}" type="button"
                            data-bs-toggle="collapse" data-bs-target="#module-collapse-{{ module.id }}"
                            aria-expanded="{{ loop.first ? 'true' : 'false' }}"
                            aria-controls="module-collapse-{{ module.id }}">
                        <i class="bi bi-folder2 me-2"></i> {{ module.titre }}
                        <span class="badge bg-light text-muted ms-2">{{ module.chapitres|length }}</span>
                    </button>
                </h3>
                <div id="module-collapse-{{ module.id }}"
                     class="accordion-collapse collapse {% if loop.first %}show{% endif %}"
                     aria-labelledby="module-heading-{{ module.id }}"
                     data-bs-parent="#modulesAccordion">
                    <div class="accordion-body p-0">
                        {% if module.chapitres|length > 0 %}
                            <ul class="list-group list-group-flush">
                                {% for chapitre in module.chapitres %}
                                    <li class="list-group-item d-flex align-items-center justify-content-between gap-2">
                                        <div class="d-flex align-items-center gap-2 min-w-0">
                                            {% if progression is defined and progression %}
                                                {% if chapitre.id in consulted_ids %}
                                                    <i class="bi bi-check-circle-fill text-success flex-shrink-0" title="Consulté"></i>
                                                {% else %}
                                                    <i class="bi bi-circle text-muted flex-shrink-0" title="Non consulté"></i>
                                                {% endif %}
                                            {% endif %}
                                            <a href="{{ path('app_chapitre_show', {id: chapitre.id}) }}" class="text-truncate">
                                                {{ chapitre.titre }}
                                            </a>
                                        </div>
                                        {% if is_granted('ROLE_ENSEIGNANT') and cours.createdBy == app.user %}
                                            <a href="{{ path('app_chapitre_edit', {id: chapitre.id}) }}" class="btn btn-icon-ghost flex-shrink-0" title="Modifier">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <div class="p-3 text-muted small">
                                Aucun chapitre dans ce module.
                                {% if is_granted('ROLE_ENSEIGNANT') and cours.createdBy == app.user %}
                                    <a href="{{ path('app_chapitre_new_from_module', {id: module.id}) }}" class="ms-1">Créer un chapitre</a>
                                {% endif %}
                            </div>
                        {% endif %}

                        {% if is_granted('ROLE_ENSEIGNANT') and cours.createdBy == app.user %}
                            <div class="p-2 border-top d-flex gap-2">
                                <a href="{{ path('app_chapitre_new_from_module', {id: module.id}) }}" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-plus-lg me-1"></i> Chapitre
                                </a>
                                <a href="{{ path('app_module_edit', {id: module.id}) }}" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-pencil me-1"></i> Module
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    {% include 'partials/_empty_state.html.twig' with {
        icon: 'folder2-open',
        text: 'Aucun module pour ce cours.',
        cta_url: is_granted('ROLE_ENSEIGNANT') and cours.createdBy == app.user ? path('app_module_new') ~ '?coursId=' ~ cours.id : null,
        cta_label: is_granted('ROLE_ENSEIGNANT') and cours.createdBy == app.user ? 'Créer un module' : null
    } only %}
{% endif %}

<div class="d-flex flex-wrap gap-2">
    {% if is_granted('ROLE_ENSEIGNANT') %}
        <a href="{{ path('enseignant_cours') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Mes cours
        </a>
        {% if cours.createdBy == app.user %}
            <a href="{{ path('app_cours_setup', {id: cours.id}) }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-gear me-1"></i> Configuration
            </a>
        {% endif %}
    {% else %}
        <a href="{{ path('app_cours') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Retour
        </a>
    {% endif %}
    <a href="{{ path('app_forum_cours', {id: cours.id}) }}" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-chat-left-text me-1"></i> Forum
    </a>
    <a href="{{ path('app_evaluations_cours', {id: cours.id}) }}" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-clipboard-check me-1"></i> Évaluations
    </a>
</div>

{% if cours.createdAt %}
    <p class="text-muted small mt-4 mb-0">
        Créé le {{ cours.createdAt|date('d/m/Y') }}
        {% if cours.createdBy %}par {{ cours.createdBy.prenom }} {{ cours.createdBy.nom }}{% endif %}
    </p>
{% endif %}
{% endblock %}
