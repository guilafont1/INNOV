{% extends 'base.html.twig' %}

{% block title %}Configuration — {{ cours.titre }}{% endblock %}

{% block body %}
{% set totalModules = cours.modules|length %}
{% set totalChapitres = 0 %}
{% for module in cours.modules %}
    {% set totalChapitres = totalChapitres + module.chapitres|length %}
{% endfor %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Configuration',
    title: cours.titre,
    description: 'Suivez les étapes pour finaliser votre cours.'
} only %}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100 {% if totalModules > 0 %}border-success{% endif %}">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Étape 1</div>
                <div class="h4 mb-0 tabular-nums">{{ totalModules }}</div>
                <div class="small text-muted">Module(s)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 {% if totalChapitres > 0 %}border-success{% endif %}">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Étape 2</div>
                <div class="h4 mb-0 tabular-nums">{{ totalChapitres }}</div>
                <div class="small text-muted">Chapitre(s)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 {% if cours.classes|length > 0 %}border-success{% endif %}">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Étape 3</div>
                <div class="h4 mb-0 tabular-nums">{{ cours.classes|length }}</div>
                <div class="small text-muted">Classe(s)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Étape 4</div>
                <div class="h4 mb-0"><i class="bi bi-calendar3"></i></div>
                <div class="small text-muted">Planning</div>
            </div>
        </div>
    </div>
</div>

{% if totalModules == 0 %}
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-2">Créer des modules</h2>
            <p class="text-muted mb-4">
                Organisez votre cours en modules thématiques. Chaque module regroupe plusieurs chapitres.
            </p>
            <a href="{{ path('app_module_new') }}?coursId={{ cours.id }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Créer le premier module
            </a>
        </div>
    </div>

{% elseif totalChapitres == 0 %}
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-2">Ajouter des chapitres</h2>
            <p class="text-muted mb-3">{{ totalModules }} module(s) créé(s). Ajoutez du contenu à chaque module.</p>
            <div class="row g-2">
                {% for module in cours.modules %}
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-medium">{{ module.titre }}</div>
                                    <div class="text-muted small">{{ module.chapitres|length }} chapitre(s)</div>
                                </div>
                                <a href="{{ path('app_chapitre_new_from_module', {id: module.id}) }}" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-plus-lg"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

{% elseif cours.classes|length == 0 %}
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-2">Assigner aux classes</h2>
            <p class="text-muted mb-4">
                Votre cours contient {{ totalModules }} module(s) et {{ totalChapitres }} chapitre(s).
                L'assignation aux classes est généralement effectuée par l'administration.
            </p>
            <div class="d-flex flex-wrap gap-2">
                <a href="{{ path('app_cours_show', {id: cours.id}) }}" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-eye me-1"></i> Voir le cours
                </a>
                <a href="{{ path('enseignant_planning_cours', {id: cours.id}) }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-calendar3 me-1"></i> Planning
                </a>
            </div>
        </div>
    </div>

{% else %}
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-2">Configuration terminée</h2>
            <p class="text-muted mb-4">
                {{ totalModules }} module(s), {{ totalChapitres }} chapitre(s), {{ cours.classes|length }} classe(s).
            </p>
            <div class="d-flex flex-wrap gap-2">
                <a href="{{ path('app_cours_show', {id: cours.id}) }}" class="btn btn-primary btn-sm">
                    <i class="bi bi-eye me-1"></i> Voir le cours
                </a>
                <a href="{{ path('enseignant_planning_cours', {id: cours.id}) }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-calendar3 me-1"></i> Planning
                </a>
                <a href="{{ path('enseignant_cours') }}" class="btn btn-outline-secondary btn-sm">
                    Mes cours
                </a>
            </div>
        </div>
    </div>
{% endif %}

<div class="card">
    <div class="card-body">
        <h2 class="h6 mb-3">Actions</h2>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_module_new') }}?coursId={{ cours.id }}" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Module
            </a>
            <a href="{{ path('app_cours_edit', {id: cours.id}) }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-pencil me-1"></i> Modifier le cours
            </a>
            <a href="{{ path('enseignant_cours') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i> Mes cours
            </a>
        </div>
    </div>
</div>
{% endblock %}
