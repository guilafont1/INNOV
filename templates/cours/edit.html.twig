{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ cours.titre }}{% endblock %}

{% block body %}
{% set headerActions %}
    <a href="{{ path('app_cours_show', {id: cours.id}) }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
{% endset %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Cours',
    title: 'Modifier le cours',
    description: cours.titre,
    actions: headerActions
} only %}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_row(form.titre) }}
                    {{ form_row(form.description) }}

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Enregistrer
                        </button>
                        <a href="{{ path('app_cours_show', {id: cours.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h2 class="h6 mb-3">Informations</h2>
                <dl class="row small mb-0">
                    <dt class="col-sm-4 text-muted">Créé le</dt>
                    <dd class="col-sm-8">{{ cours.createdAt|date('d/m/Y') }}</dd>
                    <dt class="col-sm-4 text-muted">Modules</dt>
                    <dd class="col-sm-8">{{ cours.modules|length }}</dd>
                    <dt class="col-sm-4 text-muted">Étudiants</dt>
                    <dd class="col-sm-8">{{ cours.progressions|length }}</dd>
                </dl>
            </div>
        </div>

        <div class="card border-danger">
            <div class="card-body">
                <h2 class="h6 text-danger mb-2">Supprimer le cours</h2>
                <p class="text-muted small mb-3">
                    Cette action est irréversible et supprimera les modules, chapitres et progressions associés.
                </p>
                <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal">
                    <i class="bi bi-trash me-1"></i> Supprimer
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="deleteModalLabel">Supprimer ce cours</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-2">Confirmer la suppression de <strong>{{ cours.titre }}</strong>.</p>
                <ul class="small text-muted mb-0">
                    <li>{{ cours.modules|length }} module(s)</li>
                    <li>{{ cours.progressions|length }} progression(s) étudiant</li>
                </ul>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                <form method="post" action="{{ path('app_cours_delete', {id: cours.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cours.id) }}">
                    <button type="submit" class="btn btn-danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
