{% extends 'base.html.twig' %}

{% block title %}Nouveau cours{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Enseignant',
    title: 'Créer un cours',
    description: 'Définissez le titre et la description de votre nouveau cours.'
} only %}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_row(form.titre) }}
                    {{ form_row(form.description) }}

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-1"></i> Créer le cours
                        </button>
                        <a href="{{ path('enseignant_cours') }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h2 class="h6 mb-3">Après la création</h2>
                <ol class="text-muted small mb-0 ps-3">
                    <li>Créer des modules (thèmes principaux)</li>
                    <li>Ajouter des chapitres (contenu détaillé)</li>
                    <li>Planifier les séances</li>
                    <li>Assigner le cours aux classes</li>
                </ol>
            </div>
        </div>
    </div>
</div>
{% endblock %}
