{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil{% endblock %}

{% block body %}
{% set headerActions %}
    <a href="{{ path('app_account') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
{% endset %}

{% include 'partials/_page_header.html.twig' with {
    title: 'Modifier mon profil',
    actions: headerActions
} only %}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_row(form.email) }}
                    {{ form_row(form.nom) }}
                    {{ form_rest(form) }}

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Enregistrer
                        </button>
                        <a href="{{ path('app_account') }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="text-center mt-3">
            <a href="{{ path('app_account_password') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-key me-1"></i> Changer le mot de passe
            </a>
        </div>
    </div>
</div>
{% endblock %}
