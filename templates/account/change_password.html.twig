{% extends 'base.html.twig' %}

{% block title %}Changer le mot de passe{% endblock %}

{% block body %}
{% set headerActions %}
    <a href="{{ path('app_account') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
{% endset %}

{% include 'partials/_page_header.html.twig' with {
    title: 'Changer le mot de passe',
    actions: headerActions
} only %}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_row(form.currentPassword) }}
                    {{ form_row(form.newPassword.first) }}
                    {{ form_row(form.newPassword.second) }}

                    <p class="text-muted small">Le mot de passe doit contenir au moins 6 caractères.</p>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Modifier le mot de passe
                        </button>
                        <a href="{{ path('app_account') }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="text-center mt-3">
            <a href="{{ path('app_account_edit') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-pencil me-1"></i> Modifier mon profil
            </a>
        </div>
    </div>
</div>
{% endblock %}
