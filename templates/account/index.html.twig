{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
{% set headerActions %}
    <a href="{{ path('app_account_edit') }}" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-pencil me-1"></i> Modifier
    </a>
    <a href="{{ path('app_account_password') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-key me-1"></i> Mot de passe
    </a>
{% endset %}

{% include 'partials/_page_header.html.twig' with {
    title: 'Mon compte',
    description: 'Informations personnelles et sécurité.',
    actions: headerActions
} only %}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-body">
                <h2 class="h6 mb-3">Informations personnelles</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">{{ user.email }}</dd>
                    <dt class="col-sm-4 text-muted">Nom</dt>
                    <dd class="col-sm-8">{{ user.nom ?? '—' }}</dd>
                    <dt class="col-sm-4 text-muted">Prénom</dt>
                    <dd class="col-sm-8">{{ user.prenom ?? '—' }}</dd>
                    <dt class="col-sm-4 text-muted">Rôle</dt>
                    <dd class="col-sm-8">
                        {% include 'partials/_role_badge.html.twig' %}
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h2 class="h6 mb-3">Sécurité</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Mot de passe</dt>
                    <dd class="col-sm-8">
                        <span class="text-muted">••••••••</span>
                        <div class="text-muted small mt-1">
                            Dernière modification :
                            {% if user.passwordUpdatedAt %}
                                {{ user.passwordUpdatedAt|date('d/m/Y') }}
                            {% else %}
                                jamais modifié
                            {% endif %}
                        </div>
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
{% endblock %}
