{% extends 'base.html.twig' %}

{% block title %}Créer un utilisateur{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Administration',
    title: 'Nouvel utilisateur',
    description: 'Créez un compte étudiant, enseignant ou administrateur',
    actions: '<a href="' ~ path('admin_users') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Retour</a>'
} %}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.nom) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.prenom) }}
                        </div>
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.email) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.roleChoice) }}
                        <div class="form-text text-muted">Choisissez le rôle adapté à cet utilisateur</div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.plainPassword.first) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.plainPassword.second) }}
                        </div>
                    </div>
                    <div class="alert alert-light border text-muted small mb-4">
                        <i class="bi bi-info-circle me-1"></i>
                        L'utilisateur se connectera avec l'email et le mot de passe définis ci-dessus.
                    </div>
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('admin_users') }}" class="btn btn-outline-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>Créer l'utilisateur</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
