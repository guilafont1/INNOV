{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
{% set etudiants = users|filter(u => 'ROLE_ETUDIANT' in u.roles) %}
{% set enseignants = users|filter(u => 'ROLE_ENSEIGNANT' in u.roles) %}
{% set admins_ecole = users|filter(u => 'ROLE_ADMIN_ECOLE' in u.roles) %}
{% set super_admins = users|filter(u => 'ROLE_SUPER_ADMIN' in u.roles) %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Administration',
    title: 'Utilisateurs',
    description: 'Gérez les comptes étudiants, enseignants et administrateurs',
    actions: '<a href="' ~ path('admin_dashboard') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Retour</a>
              <a href="' ~ path('admin_users_new') ~ '" class="btn btn-primary btn-sm"><i class="bi bi-person-plus me-1"></i>Nouvel utilisateur</a>'
} %}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'people', value: users|length, label: 'Total' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'mortarboard', value: etudiants|length, label: 'Étudiants' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'person-workspace', value: enseignants|length, label: 'Enseignants' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'shield-check', value: admins_ecole|length + super_admins|length, label: 'Administrateurs' } %}
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        {% if users|length > 0 %}
            <div class="table-responsive">
                <table id="datatable-users" class="table-app">
                    <thead>
                        <tr>
                            <th>Utilisateur</th>
                            <th>Email</th>
                            <th>Rôle</th>
                            <th>Dernière connexion</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            {% set isTargetSuperAdmin = 'ROLE_SUPER_ADMIN' in user.roles %}
                            {% set canManageUser = not isTargetSuperAdmin or is_granted('ROLE_SUPER_ADMIN') %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="avatar">{{ user_initials(user) }}</span>
                                        <div>
                                            <div class="fw-semibold">{{ user_full_name(user) }}</div>
                                            {% if user.classes is defined and user.classes|length > 0 %}
                                                <small class="text-muted"><i class="bi bi-building me-1"></i>{{ user.classes|first.nom }}</small>
                                            {% elseif 'ROLE_ETUDIANT' in user.roles %}
                                                <small class="text-muted">Non assigné à une classe</small>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>
                                <td>{{ user.email }}</td>
                                <td>
                                    {% include 'partials/_role_badge.html.twig' with { role: user_role_label(user) } %}
                                </td>
                                <td>
                                    {% if user.derniereConnexion %}
                                        <span class="text-muted">{{ user.derniereConnexion|date('d/m/Y H:i') }}</span>
                                    {% else %}
                                        <span class="text-muted">Jamais connecté</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% if canManageUser %}
                                    <div class="d-inline-flex gap-1">
                                        <a href="{{ path('admin_users_show', {id: user.id}) }}" class="btn btn-icon-ghost" title="Voir">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <div class="dropdown">
                                            <button class="btn btn-icon-ghost" type="button" data-bs-toggle="dropdown" aria-label="Plus d'actions">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><h6 class="dropdown-header">Changer le rôle</h6></li>
                                                {% if 'ROLE_ETUDIANT' not in user.roles %}
                                                    <li>
                                                        <form method="POST" action="{{ path('admin_users_toggle_role', {id: user.id}) }}">
                                                            <input type="hidden" name="role" value="ROLE_ETUDIANT">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_users_toggle_role_' ~ user.id) }}">
                                                            <button type="submit" class="dropdown-item"><i class="bi bi-mortarboard me-2"></i>Étudiant</button>
                                                        </form>
                                                    </li>
                                                {% endif %}
                                                {% if 'ROLE_ENSEIGNANT' not in user.roles %}
                                                    <li>
                                                        <form method="POST" action="{{ path('admin_users_toggle_role', {id: user.id}) }}">
                                                            <input type="hidden" name="role" value="ROLE_ENSEIGNANT">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_users_toggle_role_' ~ user.id) }}">
                                                            <button type="submit" class="dropdown-item"><i class="bi bi-person-workspace me-2"></i>Enseignant</button>
                                                        </form>
                                                    </li>
                                                {% endif %}
                                                {% if 'ROLE_ADMIN_ECOLE' not in user.roles %}
                                                    <li>
                                                        <form method="POST" action="{{ path('admin_users_toggle_role', {id: user.id}) }}">
                                                            <input type="hidden" name="role" value="ROLE_ADMIN_ECOLE">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_users_toggle_role_' ~ user.id) }}">
                                                            <button type="submit" class="dropdown-item"><i class="bi bi-building me-2"></i>Administration école</button>
                                                        </form>
                                                    </li>
                                                {% endif %}
                                                {% if is_granted('ROLE_SUPER_ADMIN') and 'ROLE_SUPER_ADMIN' not in user.roles %}
                                                    <li>
                                                        <form method="POST" action="{{ path('admin_users_toggle_role', {id: user.id}) }}">
                                                            <input type="hidden" name="role" value="ROLE_SUPER_ADMIN">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_users_toggle_role_' ~ user.id) }}">
                                                            <button type="submit" class="dropdown-item"><i class="bi bi-shield-lock me-2"></i>Super administrateur</button>
                                                        </form>
                                                    </li>
                                                {% endif %}
                                                {% if app.user and user.id != app.user.id %}
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <form id="delete-user-{{ user.id }}" method="POST" action="{{ path('admin_users_delete', {id: user.id}) }}">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_users_delete_' ~ user.id) }}">
                                                        </form>
                                                        <button type="button" class="dropdown-item text-danger"
                                                            data-confirm-delete
                                                            data-confirm-form="delete-user-{{ user.id }}"
                                                            data-confirm-name="{{ user_full_name(user) }}"
                                                            data-confirm-message="Le compte sera définitivement supprimé. Cette action est irréversible.">
                                                            <i class="bi bi-trash me-2"></i>Supprimer
                                                        </button>
                                                    </li>
                                                {% endif %}
                                            </ul>
                                        </div>
                                    </div>
                                    {% else %}
                                        <span class="text-muted small">Protégé</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="p-4">
                {% include 'partials/_empty_state.html.twig' with {
                    icon: 'people',
                    text: 'Aucun utilisateur enregistré',
                    cta_url: path('admin_users_new'),
                    cta_label: 'Ajouter un utilisateur'
                } %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if users|length > 0 %}
<script type="module">
    import { DataTable } from 'https://cdn.jsdelivr.net/npm/simple-datatables@9.0.4/+esm';
    new DataTable('#datatable-users', {
        searchable: true,
        perPage: 15,
        labels: {
            placeholder: 'Rechercher…',
            perPage: 'Lignes par page',
            noRows: 'Aucun utilisateur',
            info: '{start} à {end} sur {rows}',
        }
    });
</script>
{% endif %}
{% endblock %}
