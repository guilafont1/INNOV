{% extends 'base.html.twig' %}

{% block title %}Modifier {{ classe.nom }}{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Administration',
    title: 'Modifier la classe',
    description: classe.nom,
    actions: '<a href="' ~ path('admin_classes_show', {id: classe.id}) ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-eye me-1"></i>Voir</a>
              <a href="' ~ path('admin_classes_manage', {id: classe.id}) ~ '" class="btn btn-outline-primary btn-sm"><i class="bi bi-gear me-1"></i>Gérer</a>
              <a href="' ~ path('admin_classes') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Retour</a>'
} %}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_row(form.nom) }}
                    </div>
                    <div class="mb-4">
                        {{ form_row(form.description) }}
                    </div>
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('admin_classes') }}" class="btn btn-outline-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Enregistrer</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-body">
                <h2 class="h6 mb-3">Informations</h2>
                <dl class="row mb-0 small">
                    <dt class="col-sm-4 text-muted">Créée le</dt>
                    <dd class="col-sm-8">{{ classe.createdAt|date('d/m/Y H:i') }}</dd>
                    {% if classe.updatedAt %}
                        <dt class="col-sm-4 text-muted">Dernière modification</dt>
                        <dd class="col-sm-8">{{ classe.updatedAt|date('d/m/Y H:i') }}</dd>
                    {% endif %}
                    <dt class="col-sm-4 text-muted">Étudiants</dt>
                    <dd class="col-sm-8 tabular-nums">{{ classe.etudiants|length }}</dd>
                    <dt class="col-sm-4 text-muted">Enseignants</dt>
                    <dd class="col-sm-8 tabular-nums">{{ classe.professeurs|length }}</dd>
                    <dt class="col-sm-4 text-muted">Cours</dt>
                    <dd class="col-sm-8 tabular-nums">{{ classe.cours|length }}</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
{% endblock %}
