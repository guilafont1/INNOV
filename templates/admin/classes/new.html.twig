{% extends 'base.html.twig' %}

{% block title %}Créer une classe{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Administration',
    title: 'Nouvelle classe',
    description: 'Ajoutez une classe à la plateforme',
    actions: '<a href="' ~ path('admin_classes') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Retour</a>'
} %}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <div class="alert alert-light border text-muted small mb-4">
                    <i class="bi bi-info-circle me-1"></i>
                    Après la création, vous pourrez assigner des enseignants, des étudiants et des cours depuis la page de gestion.
                </div>

                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_row(form.nom) }}
                    </div>
                    <div class="mb-4">
                        {{ form_row(form.description) }}
                    </div>
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('admin_classes') }}" class="btn btn-outline-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Créer la classe</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
