{% extends 'base.html.twig' %}

{% block title %}Gérer {{ classe.nom }}{% endblock %}

{% block body %}
{% set totalModules = 0 %}
{% for cours in classe.cours %}
    {% set totalModules = totalModules + cours.modules|length %}
{% endfor %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Administration',
    title: 'Gérer la classe',
    description: classe.nom ~ (classe.description ? ' — ' ~ classe.description|slice(0, 80) : ''),
    actions: '<a href="' ~ path('admin_classes_edit', {id: classe.id}) ~ '" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil me-1"></i>Modifier</a>
              <a href="' ~ path('admin_classes_show', {id: classe.id}) ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-eye me-1"></i>Voir</a>
              <a href="' ~ path('admin_classes') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Retour</a>'
} %}

<ul class="nav nav-tabs mb-4" id="manageTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="professeurs-tab" data-bs-toggle="tab" data-bs-target="#professeurs" type="button" role="tab">
            <i class="bi bi-person-workspace me-1"></i>Enseignants
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="etudiants-tab" data-bs-toggle="tab" data-bs-target="#etudiants" type="button" role="tab">
            <i class="bi bi-mortarboard me-1"></i>Étudiants
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="cours-tab" data-bs-toggle="tab" data-bs-target="#cours" type="button" role="tab">
            <i class="bi bi-book me-1"></i>Cours
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="stats-tab" data-bs-toggle="tab" data-bs-target="#stats" type="button" role="tab">
            <i class="bi bi-bar-chart me-1"></i>Statistiques
        </button>
    </li>
</ul>

<div class="tab-content" id="manageTabsContent">
    {# Enseignants #}
    <div class="tab-pane fade show active" id="professeurs" role="tabpanel">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-body p-0">
                        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                            <h2 class="h6 mb-0">Enseignants assignés ({{ classe.professeurs|length }})</h2>
                        </div>
                        {% if classe.professeurs|length > 0 %}
                            <div class="table-responsive">
                                <table class="table-app">
                                    <thead>
                                        <tr>
                                            <th>Enseignant</th>
                                            <th>Email</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for professeur in classe.professeurs %}
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <span class="avatar">{{ user_initials(professeur) }}</span>
                                                        <span class="fw-semibold">{{ user_full_name(professeur) }}</span>
                                                    </div>
                                                </td>
                                                <td class="text-muted">{{ professeur.email }}</td>
                                                <td class="text-end">
                                                    <a href="{{ path('admin_users_show', {id: professeur.id}) }}" class="btn btn-icon-ghost" title="Voir"><i class="bi bi-eye"></i></a>
                                                    <form id="remove-teacher-{{ professeur.id }}" method="POST" action="{{ path('admin_classes_remove_teacher', {id: classe.id, teacherId: professeur.id}) }}" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_classes_remove_teacher_' ~ classe.id ~ '_' ~ professeur.id) }}">
                                                    </form>
                                                    <button type="button" class="btn btn-icon-ghost text-danger" title="Retirer"
                                                        data-confirm-delete
                                                        data-confirm-form="remove-teacher-{{ professeur.id }}"
                                                        data-confirm-name="{{ user_full_name(professeur) }}"
                                                        data-confirm-message="L'enseignant sera retiré de cette classe.">
                                                        <i class="bi bi-person-dash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="p-4">
                                {% include 'partials/_empty_state.html.twig' with { icon: 'person-workspace', text: 'Aucun enseignant assigné' } %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card">
                    <div class="card-body">
                        <h2 class="h6 mb-3">Ajouter un enseignant</h2>
                        {% if available_enseignants|filter(p => p not in classe.professeurs)|length > 0 %}
                            <form method="POST" action="{{ path('admin_classes_add_teacher', {id: classe.id}) }}" id="form-add-teacher">
                                <input type="hidden" name="_token" id="add-teacher-token" value="">
                                <div class="mb-3">
                                    <select name="teacher_id" id="add-teacher-select" class="form-select" required>
                                        <option value="">Sélectionner un enseignant</option>
                                        {% for professeur in available_enseignants %}
                                            {% if professeur not in classe.professeurs %}
                                                <option value="{{ professeur.id }}" data-token="{{ csrf_token('admin_classes_add_teacher_' ~ classe.id ~ '_' ~ professeur.id) }}">
                                                    {{ user_full_name(professeur) }} — {{ professeur.email }}
                                                </option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-person-plus me-1"></i>Ajouter</button>
                            </form>
                        {% else %}
                            {% include 'partials/_empty_state.html.twig' with { icon: 'person-check', text: 'Tous les enseignants sont déjà assignés' } %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Étudiants #}
    <div class="tab-pane fade" id="etudiants" role="tabpanel">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-body p-0">
                        <div class="p-3 border-bottom">
                            <h2 class="h6 mb-0">Étudiants inscrits ({{ classe.etudiants|length }})</h2>
                        </div>
                        {% if classe.etudiants|length > 0 %}
                            <div class="table-responsive">
                                <table class="table-app">
                                    <thead>
                                        <tr>
                                            <th>Étudiant</th>
                                            <th>Email</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for etudiant in classe.etudiants %}
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <span class="avatar">{{ user_initials(etudiant) }}</span>
                                                        <span class="fw-semibold">{{ user_full_name(etudiant) }}</span>
                                                    </div>
                                                </td>
                                                <td class="text-muted">{{ etudiant.email }}</td>
                                                <td class="text-end">
                                                    <a href="{{ path('admin_users_show', {id: etudiant.id}) }}" class="btn btn-icon-ghost" title="Voir"><i class="bi bi-eye"></i></a>
                                                    <form id="remove-student-{{ etudiant.id }}" method="POST" action="{{ path('admin_classes_remove_student', {id: classe.id, studentId: etudiant.id}) }}" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_classes_remove_student_' ~ classe.id ~ '_' ~ etudiant.id) }}">
                                                    </form>
                                                    <button type="button" class="btn btn-icon-ghost text-danger" title="Retirer"
                                                        data-confirm-delete
                                                        data-confirm-form="remove-student-{{ etudiant.id }}"
                                                        data-confirm-name="{{ user_full_name(etudiant) }}"
                                                        data-confirm-message="L'étudiant sera retiré de cette classe.">
                                                        <i class="bi bi-person-dash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="p-4">
                                {% include 'partials/_empty_state.html.twig' with { icon: 'mortarboard', text: 'Aucun étudiant inscrit' } %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card">
                    <div class="card-body">
                        <h2 class="h6 mb-3">Ajouter un étudiant</h2>
                        {% if available_etudiants|filter(e => e not in classe.etudiants)|length > 0 %}
                            <form method="POST" action="{{ path('admin_classes_add_student', {id: classe.id}) }}" id="form-add-student">
                                <input type="hidden" name="_token" id="add-student-token" value="">
                                <div class="mb-3">
                                    <select name="student_id" id="add-student-select" class="form-select" required>
                                        <option value="">Sélectionner un étudiant</option>
                                        {% for etudiant in available_etudiants %}
                                            {% if etudiant not in classe.etudiants %}
                                                <option value="{{ etudiant.id }}" data-token="{{ csrf_token('admin_classes_add_student_' ~ classe.id ~ '_' ~ etudiant.id) }}">
                                                    {{ user_full_name(etudiant) }} — {{ etudiant.email }}
                                                </option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-person-plus me-1"></i>Ajouter</button>
                            </form>
                        {% else %}
                            {% include 'partials/_empty_state.html.twig' with { icon: 'person-check', text: 'Tous les étudiants sont déjà inscrits' } %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Cours #}
    <div class="tab-pane fade" id="cours" role="tabpanel">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-body p-0">
                        <div class="p-3 border-bottom">
                            <h2 class="h6 mb-0">Cours associés ({{ classe.cours|length }})</h2>
                        </div>
                        {% if classe.cours|length > 0 %}
                            <div class="table-responsive">
                                <table class="table-app">
                                    <thead>
                                        <tr>
                                            <th>Cours</th>
                                            <th>Modules</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for cours in classe.cours %}
                                            <tr>
                                                <td>
                                                    <div class="fw-semibold">{{ cours.titre }}</div>
                                                    {% if cours.description %}
                                                        <small class="text-muted">{{ cours.description|slice(0, 60) }}{% if cours.description|length > 60 %}…{% endif %}</small>
                                                    {% endif %}
                                                </td>
                                                <td class="tabular-nums">{{ cours.modules|length }}</td>
                                                <td class="text-end">
                                                    <a href="{{ path('app_cours_show', {id: cours.id}) }}" class="btn btn-icon-ghost" title="Voir"><i class="bi bi-eye"></i></a>
                                                    <form id="remove-course-{{ cours.id }}" method="POST" action="{{ path('admin_classes_remove_course', {id: classe.id, courseId: cours.id}) }}" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_classes_remove_course_' ~ classe.id ~ '_' ~ cours.id) }}">
                                                    </form>
                                                    <button type="button" class="btn btn-icon-ghost text-danger" title="Retirer"
                                                        data-confirm-delete
                                                        data-confirm-form="remove-course-{{ cours.id }}"
                                                        data-confirm-name="{{ cours.titre }}"
                                                        data-confirm-message="Le cours sera retiré de cette classe.">
                                                        <i class="bi bi-dash-circle"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="p-4">
                                {% include 'partials/_empty_state.html.twig' with { icon: 'book', text: 'Aucun cours associé' } %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card">
                    <div class="card-body">
                        <h2 class="h6 mb-3">Ajouter un cours</h2>
                        {% if available_cours|filter(c => c not in classe.cours)|length > 0 %}
                            <form method="POST" action="{{ path('admin_classes_add_course', {id: classe.id}) }}" id="form-add-course">
                                <input type="hidden" name="_token" id="add-course-token" value="">
                                <div class="mb-3">
                                    <select name="course_id" id="add-course-select" class="form-select" required>
                                        <option value="">Sélectionner un cours</option>
                                        {% for cours in available_cours %}
                                            {% if cours not in classe.cours %}
                                                <option value="{{ cours.id }}" data-token="{{ csrf_token('admin_classes_add_course_' ~ classe.id ~ '_' ~ cours.id) }}">
                                                    {{ cours.titre }}
                                                </option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Ajouter</button>
                            </form>
                        {% else %}
                            {% include 'partials/_empty_state.html.twig' with { icon: 'book', text: 'Tous les cours sont déjà associés' } %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Statistiques #}
    <div class="tab-pane fade" id="stats" role="tabpanel">
        <div class="row g-3">
            <div class="col-sm-6 col-xl-3">
                {% include 'partials/_stat_card.html.twig' with { icon: 'person-workspace', value: classe.professeurs|length, label: 'Enseignants' } %}
            </div>
            <div class="col-sm-6 col-xl-3">
                {% include 'partials/_stat_card.html.twig' with { icon: 'mortarboard', value: classe.etudiants|length, label: 'Étudiants' } %}
            </div>
            <div class="col-sm-6 col-xl-3">
                {% include 'partials/_stat_card.html.twig' with { icon: 'book', value: classe.cours|length, label: 'Cours' } %}
            </div>
            <div class="col-sm-6 col-xl-3">
                {% include 'partials/_stat_card.html.twig' with { icon: 'layers', value: totalModules, label: 'Modules' } %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    function bindTokenSelect(selectId, tokenId) {
        var select = document.getElementById(selectId);
        var token = document.getElementById(tokenId);
        if (!select || !token) {
            return;
        }
        function updateToken() {
            var option = select.options[select.selectedIndex];
            token.value = option && option.dataset.token ? option.dataset.token : '';
        }
        select.addEventListener('change', updateToken);
        updateToken();
    }

    bindTokenSelect('add-teacher-select', 'add-teacher-token');
    bindTokenSelect('add-student-select', 'add-student-token');
    bindTokenSelect('add-course-select', 'add-course-token');
});
</script>
{% endblock %}
