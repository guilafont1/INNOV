{% extends 'base.html.twig' %}

{% block title %}Gestion des classes{% endblock %}

{% block body %}
{% set totalEtudiants = 0 %}
{% set totalProfs = 0 %}
{% set totalCours = 0 %}
{% for classe in classes %}
    {% set totalEtudiants = totalEtudiants + classe.etudiants|length %}
    {% set totalProfs = totalProfs + classe.professeurs|length %}
    {% set totalCours = totalCours + classe.cours|length %}
{% endfor %}

{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Administration',
    title: 'Classes',
    description: 'Créez et gérez les classes de la plateforme',
    actions: '<a href="' ~ path('admin_dashboard') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Retour</a>
              <a href="' ~ path('admin_classes_new') ~ '" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nouvelle classe</a>'
} %}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'building', value: classes|length, label: 'Classes' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'mortarboard', value: totalEtudiants, label: 'Étudiants inscrits' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'person-workspace', value: totalProfs, label: 'Enseignants assignés' } %}
    </div>
    <div class="col-sm-6 col-xl-3">
        {% include 'partials/_stat_card.html.twig' with { icon: 'book', value: totalCours, label: 'Cours associés' } %}
    </div>
</div>

<div class="card admin-table-card">
    <div class="card-body p-0">
        {% if classes|length > 0 %}
            <div class="table-responsive">
                <table id="datatable-classes" class="table-app">
                    <thead>
                        <tr>
                            <th>Classe</th>
                            <th>Description</th>
                            <th>Étudiants</th>
                            <th>Enseignants</th>
                            <th>Cours</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for classe in classes %}
                            <tr>
                                <td class="fw-semibold">{{ classe.nom }}</td>
                                <td class="text-muted">{{ classe.description ? classe.description|slice(0, 60) ~ (classe.description|length > 60 ? '…' : '') : '—' }}</td>
                                <td class="tabular-nums">{{ classe.etudiants|length }}</td>
                                <td class="tabular-nums">{{ classe.professeurs|length }}</td>
                                <td class="tabular-nums">{{ classe.cours|length }}</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a href="{{ path('admin_classes_show', {id: classe.id}) }}" class="btn btn-icon-ghost" title="Voir"><i class="bi bi-eye"></i></a>
                                        <a href="{{ path('admin_classes_manage', {id: classe.id}) }}" class="btn btn-icon-ghost" title="Gérer"><i class="bi bi-gear"></i></a>
                                        <div class="dropdown">
                                            <button class="btn btn-icon-ghost" type="button" data-bs-toggle="dropdown" aria-label="Plus d'actions">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><a class="dropdown-item" href="{{ path('admin_classes_edit', {id: classe.id}) }}"><i class="bi bi-pencil me-2"></i>Modifier</a></li>
                                                <li><a class="dropdown-item" href="{{ path('admin_planning', {classe: classe.id}) }}"><i class="bi bi-calendar3 me-2"></i>Planning</a></li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <form id="delete-classe-{{ classe.id }}" method="POST" action="{{ path('admin_classes_delete', {id: classe.id}) }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_classes_delete_' ~ classe.id) }}">
                                                    </form>
                                                    <button type="button" class="dropdown-item text-danger"
                                                        data-confirm-delete
                                                        data-confirm-form="delete-classe-{{ classe.id }}"
                                                        data-confirm-name="{{ classe.nom }}"
                                                        data-confirm-message="La classe et les données associées seront supprimées. Cette action est irréversible.">
                                                        <i class="bi bi-trash me-2"></i>Supprimer
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="p-4">
                {% include 'partials/_empty_state.html.twig' with {
                    icon: 'building',
                    text: 'Aucune classe créée',
                    cta_url: path('admin_classes_new'),
                    cta_label: 'Créer une classe'
                } %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if classes|length > 0 %}
<script type="module">
    import { DataTable } from 'https://cdn.jsdelivr.net/npm/simple-datatables@9.0.4/+esm';
    import { createAdminDataTableOptions } from '/js/admin-datatable.mjs';

    new DataTable('#datatable-classes', createAdminDataTableOptions({
        columns: [{ select: 5, sortable: false }],
        labels: {
            placeholder: 'Rechercher une classe…',
            noRows: 'Aucune classe trouvée',
            info: '{start}–{end} sur {rows} classes',
        },
    }));
</script>
{% endif %}
{% endblock %}
