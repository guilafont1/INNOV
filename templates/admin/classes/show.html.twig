{% extends 'base.html.twig' %}

{% block title %}{{ classe.nom }}{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: 'Administration',
    title: classe.nom,
    description: classe.description ?: 'Détails de la classe',
    actions: '<a href="' ~ path('admin_classes') ~ '" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Retour</a>
              <a href="' ~ path('admin_classes_edit', {id: classe.id}) ~ '" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil me-1"></i>Modifier</a>
              <a href="' ~ path('admin_classes_manage', {id: classe.id}) ~ '" class="btn btn-primary btn-sm"><i class="bi bi-gear me-1"></i>Gérer</a>'
} %}

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'mortarboard', value: classe.etudiants|length, label: 'Étudiants' } %}
    </div>
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'person-workspace', value: classe.professeurs|length, label: 'Enseignants' } %}
    </div>
    <div class="col-sm-4">
        {% include 'partials/_stat_card.html.twig' with { icon: 'book', value: classe.cours|length, label: 'Cours' } %}
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 mb-3"><i class="bi bi-info-circle me-2 text-muted"></i>Informations</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Nom</dt>
                    <dd class="col-sm-7">{{ classe.nom }}</dd>
                    <dt class="col-sm-5 text-muted">Description</dt>
                    <dd class="col-sm-7">{{ classe.description ?: 'Aucune description' }}</dd>
                    <dt class="col-sm-5 text-muted">Créée le</dt>
                    <dd class="col-sm-7">{{ classe.createdAt ? classe.createdAt|date('d/m/Y à H:i') : 'Non disponible' }}</dd>
                    {% if classe.updatedAt %}
                        <dt class="col-sm-5 text-muted">Modifiée le</dt>
                        <dd class="col-sm-7">{{ classe.updatedAt|date('d/m/Y à H:i') }}</dd>
                    {% endif %}
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 mb-3"><i class="bi bi-person-workspace me-2 text-muted"></i>Enseignants</h2>
                {% if classe.professeurs|length > 0 %}
                    <ul class="list-unstyled mb-0">
                        {% for prof in classe.professeurs %}
                            <li class="d-flex align-items-center gap-2 py-2 border-bottom">
                                <span class="avatar">{{ user_initials(prof) }}</span>
                                <div>
                                    <div class="fw-semibold small">{{ user_full_name(prof) }}</div>
                                    <div class="text-muted small">{{ prof.email }}</div>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-muted mb-0 small">Aucun enseignant assigné</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% if classe.etudiants and classe.etudiants|length > 0 %}
<div class="card mt-4">
    <div class="card-body p-0">
        <div class="p-3 border-bottom">
            <h2 class="h6 mb-0"><i class="bi bi-mortarboard me-2 text-muted"></i>Étudiants inscrits</h2>
        </div>
        <div class="table-responsive">
            <table class="table-app">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Email</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for etudiant in classe.etudiants %}
                        <tr>
                            <td class="fw-semibold">{{ user_full_name(etudiant) }}</td>
                            <td class="text-muted">{{ etudiant.email }}</td>
                            <td class="text-end">
                                <a href="{{ path('admin_users_show', {id: etudiant.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endif %}

{% if classe.cours and classe.cours|length > 0 %}
<div class="card mt-4">
    <div class="card-body p-0">
        <div class="p-3 border-bottom">
            <h2 class="h6 mb-0"><i class="bi bi-book me-2 text-muted"></i>Cours associés</h2>
        </div>
        <div class="table-responsive">
            <table class="table-app">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Module</th>
                        <th>Enseignant</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cours in classe.cours %}
                        <tr>
                            <td class="fw-semibold">{{ cours.titre }}</td>
                            <td class="text-muted">{{ cours.modules.count > 0 ? cours.modules.first.titre : 'Aucun module' }}</td>
                            <td class="text-muted">{{ cours.createdBy ? user_full_name(cours.createdBy) : '—' }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_cours_show', {id: cours.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
