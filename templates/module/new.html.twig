{% extends 'base.html.twig' %}

{% block title %}{% if cours %}Nouveau module — {{ cours.titre }}{% else %}Nouveau module{% endif %}{% endblock %}

{% block body %}
{% include 'partials/_page_header.html.twig' with {
    eyebrow: cours ? cours.titre : 'Module',
    title: 'Nouveau module',
    description: cours ? 'Ce module sera associé au cours sélectionné.' : 'Créez un nouveau module.'
} only %}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_row(form.titre) }}

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-1"></i> Créer le module
                        </button>
                        {% if cours %}
                            <a href="{{ path('app_cours_setup', {id: cours.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                        {% else %}
                            <a href="{{ path('app_module_index') }}" class="btn btn-outline-secondary">Annuler</a>
                        {% endif %}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h2 class="h6 mb-2">Conseils</h2>
                <ul class="text-muted small mb-0 ps-3">
                    <li>Limitez-vous à 3–7 modules par cours</li>
                    <li>Organisez du plus simple au plus complexe</li>
                    <li>Utilisez des titres courts et explicites</li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
